{
  "manifest_version": 3,
  "name": "Sumly Summarizer",
  "version": "3.0",
  "description": "Translates the entire current web page into your preferred language (English, Hindi, Telugu)",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://api.mymemory.translated.net/*",
    "https://*/*",
    "http://*/*"
  ]
}
